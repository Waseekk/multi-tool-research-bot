# Copy this to .env and fill in your values.
# Never commit .env — it is gitignored.

# ── LLM Providers (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=           # Claude Opus 4.8 / Sonnet 4.6 — primary if set
OPENAI_API_KEY=              # GPT-4o / GPT-4o-mini — used if no Anthropic key
GROQ_API_KEY=                # Llama 3.3 70B etc. — always-on emergency fallback

# ── Provider Override (optional) ─────────────────────────────────────────────
# Force a specific provider regardless of which other keys are set.
# Values: "anthropic" | "openai" | "groq"   Leave blank for auto-detection.
LLM_PROVIDER=

# ── Research Tools ────────────────────────────────────────────────────────────
TAVILY_API_KEY=              # Paid web search (optional — DuckDuckGo used if absent)
OPENWEATHER_API_KEY=         # Weather demo tool (optional)

# ── Auth ──────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=              # Password for waseekirtefa@gmail.com (auto-seeded on first run)

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8501/
